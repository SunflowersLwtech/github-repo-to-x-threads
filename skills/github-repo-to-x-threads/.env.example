# Copy to .env for local use. Never commit real tokens.

# Used by GitHub CLI and the repo context helper for live metadata.
GH_TOKEN=
GITHUB_TOKEN=
GITHUB_PERSONAL_ACCESS_TOKEN=

# Optional: official X API publishing.
# X_BEARER_TOKEN is app-only/read-oriented and is not enough to publish posts.
# Use the OAuth2 setup helper to get a user token with:
# tweet.read users.read tweet.write media.write offline.access
X_CLIENT_ID=
X_CLIENT_SECRET=
X_REDIRECT_URI=http://127.0.0.1:8765/callback
X_OAUTH2_ACCESS_TOKEN=
X_OAUTH2_REFRESH_TOKEN=
X_OAUTH2_TOKEN_EXPIRES_AT=

# Optional legacy OAuth 1.0a app-owner credentials. These are useful for some
# X workflows, but the bundled full-thread publisher uses OAuth2 user tokens.
X_CONSUMER_KEY=
X_CONSUMER_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=

# Optional: Grok/xAI evaluator for pre-publish scoring.
# xAI uses an OpenAI-compatible chat completions endpoint at https://api.x.ai/v1.
GROK_API_KEY=
GROK_MODEL=grok-4.3
